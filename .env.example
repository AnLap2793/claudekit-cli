# ============================================
# Crack Kit CLI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Note: .env files are gitignored for security

# ============================================
# GitHub Authentication
# ============================================
# GitHub Personal Access Token for accessing private repositories
# Required scopes: repo (full control of private repositories)
# Get token from: https://github.com/settings/tokens
# ⚠️  Use Classic PAT (fine-grained PATs don't work with collaborator repos)
GITHUB_TOKEN=ghp_your_github_token_here

# Alternative GitHub token variable (fallback)
GH_TOKEN=

# GitHub Enterprise hostname (if using GHE)
GH_HOST=github.com

# GitHub API rate limit buffer (requests to keep in reserve)
GITHUB_RATE_LIMIT_BUFFER=10

# ============================================
# Crack Kit Configuration
# ============================================
# Custom kit repository owner (override default)
CRACK_KIT_OWNER=

# Custom kit repository names
CRACK_KIT_ENGINEER_REPO=
CRACK_KIT_MARKETING_REPO=

# Kit download source priority
# Values: github, npm, local
CRACK_KIT_SOURCE=github

# ============================================
# CLI Behavior & Debugging
# ============================================
# Enable verbose logging (shows detailed operation logs)
# Values: 1, true, yes, on (case-insensitive)
CLAUDEKIT_VERBOSE=

# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# Log output file path
LOG_FILE=

# Enable debug mode (shows debug messages)
# Values: 1, true, yes, on
DEBUG=

# Enable performance profiling
ENABLE_PROFILING=

# Dry run mode (simulate without actual changes)
DRY_RUN=

# Disable update notifications when running `ck --version`
# Values: 1, true, yes, on
NO_UPDATE_NOTIFIER=

# Disable ANSI colors in terminal output
# Values: 1, true, yes, on
NO_COLOR=

# Force ANSI colors even in non-TTY environments
# Values: 1, 2, 3 (color depth)
FORCE_COLOR=

# ============================================
# CI/CD & Non-Interactive Mode
# ============================================
# Enable CI mode (skips interactive prompts, auto-installs dependencies)
# Values: 1, true, yes, on
CI=

# Alternative CI mode flag
CI_SAFE_MODE=

# Enable non-interactive mode (no prompts, uses defaults)
# Values: 1, true, yes, on
NON_INTERACTIVE=

# GitHub Actions environment (auto-detected)
GITHUB_ACTIONS=

# GitLab CI environment (auto-detected)
GITLAB_CI=

# CircleCI environment (auto-detected)
CIRCLECI=

# Jenkins environment (auto-detected)
JENKINS_HOME=

# ============================================
# Cache Configuration
# ============================================
# Release cache TTL in seconds (default: 3600 = 1 hour)
# Set to 0 to disable caching (always fetch fresh)
# Example: 7200 = 2 hours, 1800 = 30 minutes
CK_CACHE_TTL=3600

# ============================================
# Network & Proxy Configuration
# ============================================
# HTTP/HTTPS proxy for GitHub API requests
HTTP_PROXY=
HTTPS_PROXY=

# No proxy hosts (comma-separated)
NO_PROXY=localhost,127.0.0.1

# Custom GitHub API endpoint (for GitHub Enterprise)
GITHUB_API_URL=https://api.github.com

# Request timeout in milliseconds (default: 30000)
REQUEST_TIMEOUT=30000

# ============================================
# Path Configuration
# ============================================
# Custom Claude config directory (overrides default ~/.claude)
# Useful for testing or custom installations
CLAUDE_CONFIG_DIR=

# XDG Base Directory for config files (Linux/macOS)
# Default: ~/.config
XDG_CONFIG_HOME=

# User home directory (auto-detected, rarely needs override)
HOME=
USERPROFILE=

# ============================================
# Installation Preferences
# ============================================
# Default kit type: engineer, marketing
DEFAULT_KIT=engineer

# Default installation directory
DEFAULT_INSTALL_DIR=

# Preferred package manager: npm, pnpm, yarn, bun
PREFERRED_PACKAGE_MANAGER=

# Skip post-install hooks
SKIP_POST_INSTALL=

# Keep temporary files after installation
KEEP_TEMP_FILES=

# ============================================
# Feature Flags
# ============================================
# Enable experimental features
ENABLE_EXPERIMENTAL=

# Skip dependency installation
SKIP_DEPENDENCIES=

# Skip git operations
SKIP_GIT=

# Auto-accept all prompts (dangerous!)
AUTO_ACCEPT=

# ============================================
# Security Settings
# ============================================
# Verify checksums for downloaded files
VERIFY_CHECKSUMS=true

# Allow insecure HTTPS connections (not recommended)
ALLOW_INSECURE=

# Maximum file size for downloads (in MB)
MAX_DOWNLOAD_SIZE=500

# ============================================
# Migration Settings
# ============================================
# Auto-resolve conflicts (use 'ours' or 'theirs')
# Values: ours, theirs, prompt
AUTO_RESOLVE_CONFLICTS=prompt

# Backup before migration
BACKUP_BEFORE_MIGRATE=true

# Backup directory
BACKUP_DIR=./.ck-backups

# ============================================
# Discord Notifications (Optional)
# ============================================
# Discord webhook URL for release notifications
# Used in CI/CD pipelines to notify team of new releases
# Get webhook from: Discord Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# ============================================
# Telemetry & Analytics (Optional)
# ============================================
# Disable anonymous usage analytics
DISABLE_TELEMETRY=

# Custom analytics endpoint
ANALYTICS_ENDPOINT=

# Session ID for tracking (auto-generated if empty)
SESSION_ID=

# ============================================
# Testing & Development
# ============================================
# Test environment flag (auto-set by test runners)
NODE_ENV=

# Vitest test runner flag (auto-set)
VITEST=

# Bun test runner flag (auto-set)
BUN_TEST=

# Isolated test home directory (for test isolation)
# Used by test suite to avoid polluting real config
CK_TEST_HOME=

# Enable CLI integration tests (expensive, requires real GitHub access)
# Values: 1, true
CK_RUN_CLI_INTEGRATION=

# Specific release version for integration tests
CK_TEST_RELEASE=

# ============================================
# NPM Publishing (CI/CD Only)
# ============================================
# NPM authentication token for publishing packages
# Only needed in CI/CD release workflows
NPM_TOKEN=

# ============================================
# Platform-Specific
# ============================================
# Windows: User profile directory (auto-detected)
# USERPROFILE=C:\Users\YourUsername

# macOS/Linux: Home directory (auto-detected)
# HOME=/home/username

# ============================================
# Notes
# ============================================
# 1. Most variables are optional - CLI works with defaults
# 2. GITHUB_TOKEN is required for accessing private Crack Kit repos
# 3. Use CLAUDEKIT_VERBOSE=1 for troubleshooting
# 4. CI/NON_INTERACTIVE modes skip all prompts
# 5. NO_UPDATE_NOTIFIER=1 disables version check notifications
# 6. CK_CACHE_TTL=0 forces fresh data (useful for testing)
# 7. VERIFY_CHECKSUMS=true ensures download integrity
# 8. AUTO_ACCEPT=1 is dangerous - only use in trusted environments
