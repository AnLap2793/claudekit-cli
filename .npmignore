# Exclude tarballs to prevent nested packaging
*.tgz
*.tar.gz
dist/*.tgz

# Development files
src/
tests/
scripts/
docs/
plans/
.claude/
.github/
.githooks/

# Config files
*.config.js
*.config.ts
.releaserc.json
tsconfig.json
biome.json
.editorconfig
.gitignore

# Test artifacts
coverage/
*.test.ts
*.spec.ts

# Build artifacts that shouldn't be published
node_modules/

# Environment files
.env
.env.*
!.env.example

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Lock files (users should generate their own)
pnpm-lock.yaml
yarn.lock
bun.lockb
package-lock.json

# Temporary files
tmp/
temp/
*.tmp

# Cache
.cache/
.turbo/
*.tsbuildinfo

# Misc
*.log
*.md
!README.md
!CHANGELOG.md
!LICENSE
